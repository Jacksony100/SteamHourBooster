# Production env for docker-compose.prod.yml. Copy to .env and fill in.
#   cp .env.production.example .env

# --- Domain + SSL (Caddy auto-issues Let's Encrypt) ---
DOMAIN=deckpilot.ru
ACME_EMAIL=you@example.com           # used by Let's Encrypt for expiry notices

# --- Secrets (GENERATE THESE) ---
# SECRET_KEY:      python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
POSTGRES_DB=deckpilot
POSTGRES_USER=deckpilot
POSTGRES_PASSWORD=                   # strong random password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                      # >= 12 chars (required in production)

# --- Steam ---
# Default: transparent DEMO mode (allowed in prod via ALLOW_DEMO_MODE_IN_PRODUCTION).
STEAM_INTEGRATION_MODE=demo
STEAM_TEST_MODE=true
ALLOW_DEMO_MODE_IN_PRODUCTION=true
# To enable REAL owner-operated idle (your own accounts; see docs/REAL_SESSIONS.md):
#   STEAM_INTEGRATION_MODE=official
#   STEAM_OFFICIAL_LINKING_ENABLED=true
#   STEAM_REAL_SESSIONS_ENABLED=true
#   STEAM_API_KEY=...   # for official profile/owned-games/ban data
STEAM_OFFICIAL_LINKING_ENABLED=false
STEAM_REAL_SESSIONS_ENABLED=false

# --- FACEIT Finder (public page). Optional: keyless works without a key, but a
# free key (developers.faceit.com) gives exact, always-on stats. ---
FACEIT_API_KEY=
# Optional tuning (defaults shown): recent matches parsed, result cache TTL, ELO points.
FACEIT_MATCH_LIMIT=20
FACEIT_CACHE_TTL_SECONDS=120
FACEIT_ELO_HISTORY_SIZE=30

# --- Billing (mock is blocked in prod; set coinbase for real crypto checkout) ---
BILLING_PROVIDER=mock                # 'mock' here disables paid checkout in prod
# BILLING_PROVIDER=coinbase
# COINBASE_API_KEY=
# COINBASE_WEBHOOK_SECRET=

# --- Email (console = no real send; smtp = real recovery/verification emails) ---
EMAIL_PROVIDER=console
EMAIL_FROM=DeckPilot <no-reply@deckpilot.ru>
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=

# --- Optional demo login on the deployed site ---
SEED_DEMO_USER=true
DEMO_USERNAME=demo
DEMO_PASSWORD=                       # set if SEED_DEMO_USER=true

# --- Observability (optional) ---
SENTRY_DSN=
LOG_LEVEL=INFO
