APP_ENV=development
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000/api/v1
INTERNAL_API_ORIGIN=http://api:8000
NEXT_PUBLIC_API_BASE_PATH=/api/v1
CORS_ORIGINS=http://localhost:3000
SESSION_COOKIE_NAME=deckpilot_session
CSRF_COOKIE_NAME=deckpilot_csrf
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

POSTGRES_DB=deckpilot
POSTGRES_USER=deckpilot
POSTGRES_PASSWORD=deckpilot
DATABASE_URL=postgresql+psycopg://deckpilot:deckpilot@postgres:5432/deckpilot
REDIS_URL=redis://redis:6379/0

# Generate before first run. SECRET_KEY must be at least 32 characters.
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-generated-fernet-key
STEAM_API_KEY=
STEAM_TEST_MODE=true
STEAM_INTEGRATION_MODE=demo
STEAM_OFFICIAL_LINKING_ENABLED=false
ALLOW_DEMO_MODE_IN_PRODUCTION=false
# REAL owner-operated idle sessions (worker logs into YOUR account + idles games so
# hours accrue). OFF by default. Requires STEAM_INTEGRATION_MODE=official +
# STEAM_OFFICIAL_LINKING_ENABLED=true. Only for accounts you own; requires the
# account credentials + a Steam Guard code per session. No evasion/anti-detect.
# Account-ban risk is real and yours — see docs/REAL_SESSIONS.md.
STEAM_REAL_SESSIONS_ENABLED=false
STEAM_SESSION_MAX_MINUTES=720
# After first real login captures a refresh token, drop the stored password so the
# account re-authenticates via the (revocable) token instead of the password.
STEAM_DROP_PASSWORD_AFTER_LINK=true

# Observability
LOG_LEVEL=INFO
# Production always emits JSON logs; set true to force JSON in dev too.
LOG_JSON=false
# Optional error tracking. Blank = disabled (also a no-op unless sentry-sdk is installed).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Public FACEIT Finder page (no login). Works WITHOUT a key by default — it uses
# FACEIT's public web endpoints + Steam profile XML (keyless). Set a server-side
# key (https://developers.faceit.com) to use the official Data API, which is more
# reliable and rate-limit-friendly. Optional.
FACEIT_API_KEY=
# FACEIT Finder tuning (all optional; defaults shown). A lookup fans out to many
# FACEIT calls, so results are cached. Match limit 0–50, ELO history 0–100.
FACEIT_MATCH_LIMIT=20                 # recent matches parsed in detail (official API)
FACEIT_CACHE_TTL_SECONDS=120          # per-query result cache TTL (0 disables caching)
FACEIT_ELO_HISTORY_SIZE=30            # points in the ELO trend chart

BILLING_PROVIDER=mock
BILLING_CURRENCY=USD
COINBASE_API_KEY=
COINBASE_WEBHOOK_SECRET=
COINBASE_CHARGE_URL=https://api.commerce.coinbase.com/charges
ENABLE_LIFETIME_CHECKOUT=false

ADMIN_USERNAME=admin
# Replace before running docker compose or production startup.
ADMIN_PASSWORD=replace-admin-password-before-deploy

# Optional demo user (closed-beta demos + web smoke harness). Off by default.
SEED_DEMO_USER=false
DEMO_USERNAME=demo
DEMO_PASSWORD=demo-password-123

# Email (transactional). console = log + in-memory outbox (dev); smtp = real send.
EMAIL_PROVIDER=console
EMAIL_FROM=DeckPilot <no-reply@deckpilot.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Production notes:
# APP_ENV=production
# WEB_BASE_URL=https://deckpilot.example.com
# API_BASE_URL=https://deckpilot.example.com
# CORS_ORIGINS=https://deckpilot.example.com
# COOKIE_SECURE=true
# BILLING_PROVIDER=coinbase
# STEAM_INTEGRATION_MODE=demo or STEAM_TEST_MODE=true requires ALLOW_DEMO_MODE_IN_PRODUCTION=true and must be visibly labeled as demo/beta.
